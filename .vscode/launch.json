{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: WXT dev (Chrome)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Preview: Production build (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "https://www.dndbeyond.com/characters/166869100",
      "runtimeArgs": [
        "--disable-extensions-except=${workspaceFolder}/.output/chrome-mv3",
        "--load-extension=${workspaceFolder}/.output/chrome-mv3"
      ],
      "preLaunchTask": "wxt: build",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
