{
  "name": "enhanced-dndbeyond-sheets",
  "description": "Enhanced D&D Beyond character sheets browser extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haywoodsloan/enhanced-dndbeyond-sheets.git"
  },
  "homepage": "https://github.com/haywoodsloan/enhanced-dndbeyond-sheets#readme",
  "bugs": "https://github.com/haywoodsloan/enhanced-dndbeyond-sheets/issues",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "check": "npm run lint && npm run compile && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "wxt build && playwright test",
    "test:e2e:headed": "wxt build && playwright test --headed",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@primeuix/themes": "^3.0.0",
    "primevue": "^5.0.0",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "@wxt-dev/module-vue": "^1.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.11.1",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.8",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "esbuild": "0.28.1",
    "shell-quote": "1.10.0",
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  }
}
